// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "icon_theme": "Material Icon Theme",
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
  },
  "tabs": {
    "git_status": true,
    "file_icons": true,
  },
  "ui_font_size": 14,
  "buffer_font_size": 14,
  "buffer_font_family": "JetBrains Mono",
  "terminal": {
    "font_family": "Hack Nerd Font",
    "font_size": 12,
  },
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Night Owl Dark",
  },
  "lsp": {
    "intelephense": {
      "settings": {
        "diagnostics": {
          "exclude": {
            "**/*.php": ["P1132", "P1101", "P1114", "P1116"],
          },
        },
      },
    },
  },
  "languages": {
    "PHP": {
      "language_servers": ["intelephense", "!phpactor", "!phptools", "..."],
      "formatter": [
        { "language_server": { "name": "intelephense" } },
        {
          "external": {
            "command": "perl",
            "arguments": ["-0777", "-pe", "s/\\z/\\n/ unless /\\n\\z/"],
          },
        },
      ],
    },
    "Twig": {
      "format_on_save": "on",
      "language_servers": ["twiggy-language-server"],
      "formatter": "language_server",
    },
  },
}
